# Analysis engine configuration.
# Copy to .env to override. Every value has a working default, so the service
# runs without this file in development.

# Comma-separated origins permitted to call the API.
# VERISIGHT_ALLOWED_ORIGINS=["http://localhost:3000"]

# Hard limits, enforced before any decode.
# VERISIGHT_MAX_UPLOAD_BYTES=26214400
# VERISIGHT_MAX_PIXELS=50000000

# Long edge images are downscaled to before the pixel-statistics analyzers.
# VERISIGHT_ANALYSIS_LONG_EDGE=1024
